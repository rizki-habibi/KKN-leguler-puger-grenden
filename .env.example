# ─── Database ────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Jika tanpa password (Laragon default): mysql://root@127.0.0.1:3306/kkn_grenden
DATABASE_URL=mysql://root@127.0.0.1:3306/kkn_grenden

# ─── Server API ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Digunakan untuk menandatangani token admin (HMAC SHA-256)
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Password login panel admin (/admin)
ADMIN_PASSWORD=ganti-password-admin-anda

# PIN untuk fitur Buku Tamu (mode humas)
HUMAS_PIN=humas2026

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_PORT=3000
BASE_PATH=/

# URL backend API — dipakai oleh Vite dev proxy
VITE_API_URL=http://localhost:5000

# ─── Google Gemini AI (opsional) ─────────────────────────────
# Dapatkan API key di: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=masukkan_api_key_gemini_disini
GEMINI_API_KEY=masukkan_api_key_gemini_disini
